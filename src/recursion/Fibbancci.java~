package recursion;

public class Fibbancci {
    public static void main(String[] args) {
        int ans=fibbo(5);
        System.out.println("ans = " + ans);
    }
    static int fibbo(int n){
        if(n==0|| n==1)
            return n;

        System.out.println(n);

        return fibbo(n-1)+fibbo(n-2);
    }
}
